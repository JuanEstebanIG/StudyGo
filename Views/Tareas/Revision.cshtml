@model StudyGo.ViewModels.Tareas.TareaRevisionViewModel

@{
    ViewData["Title"] = "Revisar: " + Model.TaskTitle;
}

<div class="h-[calc(100vh-140px)] flex gap-6" id="revision-workspace" data-task-id="@Model.TaskId">
    <!-- PANEL IZQUIERDO: Directorio de Estudiantes -->
    <div class="w-80 flex flex-col bg-dark-card border border-dark-border rounded-2xl overflow-hidden h-full">
        <div class="p-4 bg-dark-elev/50 border-b border-dark-border flex flex-col gap-1.5">
            <h2 class="text-sm font-bold text-white font-title flex items-center gap-1.5">
                <i class="fa-solid fa-users text-brand-blue"></i> Estudiantes inscritos
            </h2>
            <div class="text-[10px] text-dark-muted font-mono uppercase tracking-wider">
                @Model.Submissions.Count(s => s.Status == "Enviado" || s.Status == "Calificado") / @Model.Submissions.Count entregas
            </div>
        </div>

        <div class="flex-grow overflow-y-auto divide-y divide-dark-border/40">
            @foreach (var sub in Model.Submissions)
            {
                var isSelected = Model.SelectedStudentId == sub.StudentId;
                <a asp-action="Revision" asp-route-id="@Model.TaskId" asp-route-studentId="@sub.StudentId"
                   class="block p-4 text-left transition @(isSelected ? "bg-white/5 border-l-2 border-brand-blue" : "hover:bg-dark-elev/30")">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-brand-blue/15 text-brand-blue flex items-center justify-center font-bold text-xs">
                            @(sub.StudentName.Substring(0, 2).ToUpper())
                        </div>
                        <div class="flex-grow min-w-0">
                            <span class="text-xs font-semibold text-gray-200 block truncate">@sub.StudentName</span>
                            <span class="text-[10px] text-dark-muted truncate block">@sub.StudentEmail</span>
                        </div>
                    </div>

                    <div class="flex items-center justify-between mt-3 text-[10px] font-mono">
                        <span class="badge @(sub.Status == "Calificado" ? "badge-success scale-90" : (sub.Status == "Enviado" ? "badge-info scale-90" : "badge-neutral scale-90"))">
                            @sub.Status
                        </span>
                        @if (sub.Score.HasValue)
                        {
                            <span class="text-white font-bold">@sub.Score.Value.ToString("0.#")/100</span>
                        }
                        else if (sub.LastUpdate.HasValue)
                        {
                            <span class="text-dark-muted">@sub.LastUpdate.Value.ToString("dd MMM HH:mm")</span>
                        }
                        else
                        {
                            <span class="text-dark-muted/40">-</span>
                        }
                    </div>
                </a>
            }
        </div>
    </div>

    <!-- PANEL DERECHO: Visor de Código y Calificación -->
    <div class="flex-grow flex flex-col h-full overflow-hidden">
        @if (!Model.SelectedStudentId.HasValue)
        {
            <div class="card flex-grow flex flex-col items-center justify-center text-center p-12">
                <div class="w-16 h-16 rounded-full bg-white/5 border border-dark-border flex items-center justify-center text-dark-muted text-2xl mb-4">
                    <i class="fa-solid fa-code-pull-request"></i>
                </div>
                <h3 class="text-lg font-bold text-white font-title">Evaluación de Entregas</h3>
                <p class="text-sm text-dark-muted mt-2 max-w-sm">Selecciona un estudiante de la lista de la izquierda para revisar el historial de código y calificar utilizando la rúbrica.</p>
            </div>
        }
        else
        {
            <div class="flex-grow flex flex-col md:flex-row gap-6 h-full overflow-hidden">
                <!-- Visor Monaco (Lectura) -->
                <div class="flex-grow flex flex-col bg-dark-card border border-dark-border rounded-2xl overflow-hidden h-full">
                    <!-- Cabecera del archivo/entrega -->
                    <div class="h-14 bg-dark-elev/80 border-b border-dark-border px-4 flex items-center justify-between select-none">
                        <div class="flex items-center gap-2">
                            <span class="font-mono text-xs text-gray-300 font-semibold"><i class="fa-solid fa-file-code text-brand-blue"></i> Código Entregado: @Model.SelectedStudentName</span>
                            <span class="badge badge-neutral text-[9px] font-mono scale-90"><i class="fa-solid fa-lock mr-0.5"></i> Sólo Lectura</span>
                        </div>
                        
                        <!-- Selector de Versión -->
                        @if (Model.Versions.Any())
                        {
                            <div class="flex items-center gap-1.5 text-xs text-dark-muted">
                                <span class="font-mono text-[10px]">Versiones:</span>
                                <select id="revision-version-select" class="bg-dark-elev border border-dark-border text-gray-200 rounded px-2.5 py-1 text-xs focus:outline-none">
                                    @foreach (var version in Model.Versions)
                                    {
                                        <option value="@version.Id" data-version-num="@version.VersionNumber">V#@version.VersionNumber (@version.SavedAt.ToString("dd/MM HH:mm"))</option>
                                    }
                                </select>
                            </div>
                        }
                    </div>

                    <!-- Monaco Container -->
                    <div id="revision-monaco-container" class="flex-grow w-full h-[60%]"></div>
                </div>

                <!-- Tarjeta de Calificación y Rúbricas -->
                <div class="w-80 flex flex-col bg-dark-card border border-dark-border rounded-2xl overflow-y-auto h-full p-5 space-y-6">
                    <div class="border-b border-dark-border/40 pb-3">
                        <h3 class="text-sm font-bold text-white font-title uppercase tracking-wider font-mono">Calificación</h3>
                        <p class="text-[10px] text-dark-muted mt-0.5">Tarea evaluada en base a 100 puntos.</p>
                    </div>

                    <form asp-action="Calificar" method="post" class="space-y-6 flex-grow flex flex-col justify-between">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="submissionId" value="@Model.SelectedSubmissionId" />
                        <input type="hidden" name="taskId" value="@Model.TaskId" />
                        <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />

                        <div class="space-y-5">
                            <!-- Input de Score -->
                            <div class="space-y-1.5">
                                <label class="label">Puntuación Final</label>
                                <div class="relative flex items-center">
                                    <input type="number" name="score" min="0" max="100" class="input pr-12 font-mono text-lg font-bold" 
                                           value="@(Model.FinalScore.HasValue ? Model.FinalScore.Value.ToString("0") : "")" required placeholder="0-100" />
                                    <span class="absolute right-4 text-xs font-mono text-dark-muted">/100</span>
                                </div>
                            </div>

                            <!-- Enlace a evaluación por rúbrica de Negro -->
                            <div class="p-3.5 bg-brand-blue/5 border border-brand-blue/20 rounded-xl space-y-2">
                                <div class="flex items-center justify-between text-xs font-bold text-gray-200">
                                    <span>Rúbrica Evaluativa</span>
                                    <span class="text-[10px] font-mono text-brand-blue">Negro Module</span>
                                </div>
                                <p class="text-[10px] text-dark-muted leading-relaxed">
                                    Accede a la plantilla de rúbricas para evaluar criterios específicos y calcular la nota de forma automatizada.
                                </p>
                                <button type="button" onclick="showToast('Redireccionando al evaluador de rúbricas de Negro...', 'info')" 
                                        class="w-full btn btn-sm btn-secondary hover:text-white justify-center text-[10px]">
                                    <i class="fa-solid fa-square-poll-horizontal mr-1"></i> Abrir Evaluador
                                </button>
                            </div>

                            <!-- Input Feedback -->
                            <div class="space-y-1.5">
                                <label class="label">Retroalimentación / Comentarios</label>
                                <textarea name="feedback" rows="4" class="input resize-none text-xs" placeholder="Escribe tus observaciones para el estudiante...">@Model.Feedback</textarea>
                            </div>
                        </div>

                        <div class="pt-4 border-t border-dark-border/40">
                            <button type="submit" class="w-full btn btn-md btn-primary justify-center">
                                Publicar Calificación <i class="fa-solid fa-check-circle text-xs"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <!-- Cargar RequireJS para Monaco Editor -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/require.js/2.3.6/require.min.js"></script>
    <script>
        window.StudyGo_SelectedCode = @Json.Serialize(Model.SelectedCode);
    </script>
    <script src="~/js/tareas.js" asp-append-version="true"></script>
}
