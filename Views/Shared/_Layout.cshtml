<!DOCTYPE html>
<html lang="es" class="h-full bg-slate-950 text-slate-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyGo</title>
    <link rel="stylesheet" href="~/css/build.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.output.css" />
    <link rel="stylesheet" href="~/css/tailwind.output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StudyGo.styles.css" asp-append-version="true" />
</head>
<body class="flex flex-col min-h-screen font-sans antialiased selection:bg-indigo-500/30 selection:text-indigo-200">

    <header class="sticky top-0 z-40 w-full border-b border-slate-800 bg-slate-900/80 backdrop-blur-md">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex h-16 items-center justify-between">

                <div class="flex items-center gap-8">
                    <a class="text-xl font-bold tracking-tight text-white hover:text-indigo-400 transition-colors duration-200" asp-area="" asp-controller="Home" asp-action="Index">
                        Study<span class="text-indigo-500">Go</span>
                    </a>

                    <nav class="hidden md:flex items-center gap-6">
                        <a class="text-sm font-medium text-slate-300 hover:text-white transition-colors duration-200" asp-area="" asp-controller="Home" asp-action="Index">
                            Inicio
                        </a>
                        <a class="text-sm font-medium text-slate-300 hover:text-white transition-colors duration-200" asp-area="" asp-controller="Home" asp-action="Privacy">
                            Privacidad
                        </a>
                    </nav>
                </div>

                <div class="flex md:hidden">
                    <button type="button" class="inline-flex items-center justify-center rounded-md p-2 text-slate-400 hover:bg-slate-800 hover:text-white focus:outline-none">
                        <span class="sr-only">Abrir menú</span>
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                        </svg>
                    </button>
                </div>

            </div>
        </div>
    </header>

    <div class="mx-auto w-full max-w-7xl flex-grow px-4 py-8 sm:px-6 lg:px-8">
        <main role="main" class="animate-fade-in">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-auto border-t border-slate-900 bg-slate-900/40 py-6 text-center text-sm text-slate-500">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
            <div>
                &copy; 2026 - <span class="text-slate-400 font-medium">StudyGo</span>. Todos los derechos reservados.
            </div>
            <div class="flex gap-4">
                <a class="hover:text-indigo-400 transition-colors duration-200" asp-area="" asp-controller="Home" asp-action="Privacy">Política de Privacidad</a>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>