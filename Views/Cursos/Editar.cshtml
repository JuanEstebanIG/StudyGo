@model StudyGo.ViewModels.Cursos.CursoCrearEditarViewModel

@{
    ViewData["Title"] = "Editar Curso";
    var backAction = User.IsInRole("Administrador") ? "Admin" : "Index";
}

<div class="max-w-xl mx-auto space-y-6 font-sans antialiased">
    <div class="flex items-center gap-2">
        @if (User.IsInRole("Administrador"))
        {
            <a asp-action="Admin" class="text-xs text-dark-muted hover:text-white transition-colors">Panel de Cursos</a>
            <span class="text-xs text-dark-muted">/</span>
        }
        else
        {
            <a asp-action="Index" class="text-xs text-dark-muted hover:text-white transition-colors">Mis Cursos</a>
            <span class="text-xs text-dark-muted">/</span>
            <a asp-action="Detalle" asp-route-id="@Model.Id" class="text-xs text-dark-muted hover:text-white transition-colors">@Model.Name</a>
            <span class="text-xs text-dark-muted">/</span>
        }
        <span class="text-xs text-brand-blue font-mono">Configuración</span>
    </div>

    <div class="card p-8">
        <div class="border-b border-dark-border pb-4 mb-6">
            <h2 class="text-2xl font-extrabold tracking-tight text-white font-title text-gradient">Editar Curso</h2>
            <p class="text-xs text-dark-muted mt-1">Actualiza los datos del curso seleccionado.</p>
        </div>

        <form asp-action="Editar" asp-route-id="@Model.Id" method="post" class="space-y-6">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-xs text-red-400 font-medium"></div>

            <!-- Nombre del Curso -->
            <div>
                <label asp-for="Name" class="label"></label>
                <input asp-for="Name"
                       class="block w-full rounded-xl border border-slate-800/80 bg-slate-950/60 p-3 text-xs text-white placeholder-slate-600 focus:border-indigo-500/80 focus:ring-4 focus:ring-indigo-500/10 focus:bg-slate-950 transition-all outline-none"
                       autocomplete="off" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <!-- Código del Curso -->
            <div>
                <label asp-for="Code" class="label"></label>
                <input asp-for="Code"
                       class="block w-full rounded-xl border border-slate-800/80 bg-slate-950/60 p-3 text-xs text-white font-mono placeholder-slate-600 focus:border-indigo-500/80 focus:ring-4 focus:ring-indigo-500/10 focus:bg-slate-950 transition-all outline-none"
                       autocomplete="off" />
                <span asp-validation-for="Code" class="field-error"></span>
            </div>

            <div class="flex items-center justify-end gap-3 pt-4 border-t border-dark-border/40">
                <a asp-action="@backAction" class="btn btn-md btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-md btn-primary">
                    Guardar Cambios <i class="fa-solid fa-save text-xs"></i>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}