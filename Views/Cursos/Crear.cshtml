@model StudyGo.ViewModels.Cursos.CursoCrearEditarViewModel

@{
    ViewData["Title"] = "Crear Curso";
}

<div class="max-w-xl mx-auto space-y-6">
    <div class="flex items-center gap-2">
        <a asp-action="Index" class="text-xs text-dark-muted hover:text-white transition-colors">Cursos</a>
        <span class="text-xs text-dark-muted">/</span>
        <span class="text-xs text-brand-blue font-mono">Crear nuevo curso</span>
    </div>

    <div class="card p-8">
        <div class="border-b border-dark-border pb-4 mb-6">
            <h2 class="text-2xl font-extrabold tracking-tight text-white font-title text-gradient">Nuevo Curso</h2>
            <p class="text-xs text-dark-muted mt-1">Configura una nueva aula de clases para tu institución académica.</p>
        </div>

        <form asp-action="Crear" method="post" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-xs text-red-400 font-medium"></div>

            <div>
                <label asp-for="Name" class="label"></label>
                <input asp-for="Name" class="input" placeholder="Ej. Estructuras de Datos I" autocomplete="off" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <div>
                <label asp-for="Code" class="label"></label>
                <input asp-for="Code" class="input font-mono" placeholder="Ej. CS-301" autocomplete="off" />
                <span asp-validation-for="Code" class="field-error"></span>
            </div>

            <div class="flex items-center justify-end gap-3 pt-4 border-t border-dark-border/40">
                <a asp-action="Index" class="btn btn-md btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-md btn-primary">
                    Crear Curso <i class="fa-solid fa-arrow-right text-xs"></i>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
