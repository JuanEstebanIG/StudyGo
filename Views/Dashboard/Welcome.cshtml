@{
    Layout = null; // Pantalla limpia de Onboarding enfocada en la bienvenida
    ViewData["Title"] = "¡Bienvenido a StudyGo!";
    var userName = ViewData["UserName"] as string;
    var userRole = ViewData["UserRole"] as string;
}

<!DOCTYPE html>
<html lang="es" class="h-full bg-slate-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="h-full flex items-center justify-center p-4 sm:p-6 lg:p-8">

    <div class="w-full max-w-xl text-center space-y-8 bg-white p-10 rounded-2xl border border-slate-200/80 shadow-xl shadow-slate-100">

        <div class="mx-auto h-16 w-16 rounded-2xl bg-indigo-50 flex items-center justify-center text-indigo-600 border border-indigo-100 shadow-sm animate-bounce">
            <svg class="h-8 w-8" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
        </div>

        <div class="space-y-3">
            <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
                ¡Configuración Exitosa, @userName!
            </h1>
            <p class="text-base text-slate-500 max-w-md mx-auto leading-relaxed">
                Tu cuenta ha sido vinculada correctamente con las credenciales de la institución educativa.
            </p>
        </div>

        <div class="bg-slate-50 border border-slate-200/60 rounded-xl p-5 inline-block w-full max-w-sm">
            <span class="text-xs font-semibold uppercase tracking-wider text-slate-400 block mb-1">Rol de Acceso Asignado</span>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-indigo-50 text-indigo-700 text-sm font-bold border border-indigo-100">
                <span class="h-2 w-2 rounded-full bg-indigo-500 animate-pulse"></span>
                @userRole
            </div>
        </div>

        <p class="text-xs text-slate-400">
            A partir de ahora, puedes usar este mismo método rápido de acceso para omitir las contraseñas tradicionales.
        </p>

        <div class="pt-2">
            <a asp-controller="Dashboard" asp-action="GoToDashboard"
               class="inline-flex items-center justify-center w-full max-w-sm px-6 py-3.5 text-sm font-semibold text-white bg-slate-900 hover:bg-slate-800 focus:ring-4 focus:ring-slate-950/20 rounded-xl shadow-sm transition-all duration-150 group">
                Ir a mi panel de control
                <svg class="ml-2 h-4 w-4 transform transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
            </a>
        </div>
        <div>
            <a asp-controller="Auth" asp-action="Logout"
               class="inline-flex items-center justify-center rounded-xl bg-white border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 transition w-full sm:w-auto">
                Cambiar de Cuenta
            </a>
        </div>
    </div>
</body>
</html>