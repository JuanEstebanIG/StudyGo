@model StudyGo.ViewModels.StudentQuizViewModel
@{
    ViewData["Title"] = "Mis Evaluaciones";
}

<div class="mb-8">
    <h1 class="text-2xl font-bold text-white tracking-tight">Mis Evaluaciones</h1>
    <p class="text-sm text-slate-400 mt-1">Aquí encontrarás los quizzes disponibles para tus cursos inscritos y tu historial de intentos.</p>
</div>

<!-- Toast de error/éxito -->
@if (TempData["ErrorMessage"] != null)
{
    <div id="toast-message" class="mb-6 flex items-center gap-3 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300 transition-all duration-500">
        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3Z" />
        </svg>
        <span>@TempData["ErrorMessage"]</span>
    </div>
}

<div class="mb-10">
    <h2 class="text-lg font-semibold text-white mb-4 border-b border-slate-800 pb-2">Quizzes Disponibles</h2>
    
    @if (Model.ActiveQuizzes.Any(q => !q.HasCompletedAttempt || q.RemainingAttempts > 0))
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var quiz in Model.ActiveQuizzes.Where(q => !q.HasCompletedAttempt || q.RemainingAttempts > 0))
            {
                <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-5 flex flex-col transition-all hover:border-indigo-500/50 hover:shadow-lg hover:shadow-indigo-500/10 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-indigo-500 to-purple-500"></div>
                    
                    <div class="mb-3">
                        <span class="inline-block px-2.5 py-1 rounded-md bg-indigo-500/10 text-indigo-400 text-xs font-medium mb-2 border border-indigo-500/20">
                            @quiz.CourseName
                        </span>
                        <h3 class="text-lg font-bold text-white line-clamp-1">@quiz.Title</h3>
                    </div>
                    
                    <p class="text-sm text-slate-400 mb-5 line-clamp-2 flex-grow">@quiz.Description</p>
                    
                    <div class="space-y-2 text-sm text-slate-300 mb-5 bg-slate-800/50 rounded-lg p-3">
                        <div class="flex items-center justify-between">
                            <span class="flex items-center gap-1.5">
                                <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>
                                Duración:
                            </span>
                            <span class="font-medium text-white">@quiz.TimeLimitMinutes min</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="flex items-center gap-1.5">
                                <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
                                </svg>
                                Preguntas:
                            </span>
                            <span class="font-medium text-white">@quiz.QuestionCount</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="flex items-center gap-1.5">
                                <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                                </svg>
                                Fecha límite:
                            </span>
                            <span class="font-medium text-white">@(quiz.DueDate?.ToString("dd/MM/yyyy HH:mm") ?? "Sin límite")</span>
                        </div>
                        <div class="flex items-center justify-between pt-2 mt-2 border-t border-slate-700/50">
                            <span class="text-xs text-slate-400">Intentos restantes:</span>
                            <span class="text-xs font-bold px-2 py-0.5 rounded bg-indigo-500/20 text-indigo-300">
                                @quiz.RemainingAttempts / @quiz.MaxAttempts
                            </span>
                        </div>
                    </div>
                    
                    <div class="mt-auto">
                        @{
                            bool isOpen = !quiz.OpenDate.HasValue || quiz.OpenDate.Value <= DateTime.Now;
                            bool isClosed = quiz.DueDate.HasValue && quiz.DueDate.Value < DateTime.Now;
                        }

                        @if (!isOpen)
                        {
                            <button disabled class="w-full rounded-lg bg-slate-800 py-2.5 text-sm font-semibold text-slate-400 cursor-not-allowed">
                                Disponible el @quiz.OpenDate.Value.ToString("dd/MM HH:mm")
                            </button>
                        }
                        else if (isClosed)
                        {
                            <button disabled class="w-full rounded-lg bg-red-500/10 border border-red-500/20 py-2.5 text-sm font-semibold text-red-400 cursor-not-allowed">
                                Cerrado
                            </button>
                        }
                        else
                        {
                            <a asp-action="Take" asp-route-quizId="@quiz.QuizId" class="w-full inline-flex items-center justify-center gap-2 rounded-lg bg-indigo-600 py-2.5 text-sm font-semibold text-white transition-all hover:bg-indigo-500 shadow-lg shadow-indigo-500/20">
                                Iniciar Quiz
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                                </svg>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="rounded-xl border border-slate-800 bg-slate-900/30 p-8 text-center">
            <svg class="mx-auto h-12 w-12 text-slate-600 mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
            </svg>
            <h3 class="text-lg font-medium text-white mb-1">No hay quizzes pendientes</h3>
            <p class="text-sm text-slate-400">Has completado todas tus evaluaciones o no hay ninguna activa en este momento.</p>
        </div>
    }
</div>

<div>
    <h2 class="text-lg font-semibold text-white mb-4 border-b border-slate-800 pb-2">Historial de Intentos</h2>
    
    @if (Model.AttemptHistory.Any())
    {
        <div class="rounded-xl border border-slate-800 bg-slate-900/50 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead class="bg-slate-800/50 border-b border-slate-800">
                        <tr>
                            <th class="px-4 py-3 font-medium text-slate-400">Quiz</th>
                            <th class="px-4 py-3 font-medium text-slate-400">Curso</th>
                            <th class="px-4 py-3 font-medium text-slate-400">Enviado</th>
                            <th class="px-4 py-3 font-medium text-slate-400">Tiempo Usado</th>
                            <th class="px-4 py-3 font-medium text-slate-400">Nota</th>
                            <th class="px-4 py-3 text-right font-medium text-slate-400">Acción</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
                        @foreach (var attempt in Model.AttemptHistory)
                        {
                            <tr class="hover:bg-slate-800/30 transition-colors">
                                <td class="px-4 py-3 font-medium text-white">@attempt.QuizTitle</td>
                                <td class="px-4 py-3 text-slate-400">@attempt.CourseName</td>
                                <td class="px-4 py-3 text-slate-300">@attempt.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-4 py-3 font-mono text-slate-300">@attempt.TimeSpentDisplay</td>
                                <td class="px-4 py-3">
                                    @{
                                        var scoreColor = attempt.Score >= 60 ? "text-emerald-400" : "text-red-400";
                                    }
                                    <span class="font-bold @scoreColor">@attempt.Score / 100</span>
                                </td>
                                <td class="px-4 py-3 text-right">
                                    <a asp-action="Result" asp-route-attemptId="@attempt.AttemptId" class="inline-flex items-center gap-1 text-indigo-400 hover:text-indigo-300 font-medium">
                                        Ver Detalles
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                                        </svg>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="rounded-xl border border-slate-800 bg-slate-900/30 p-8 text-center">
            <p class="text-sm text-slate-500">Aún no tienes historial de intentos.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Ocultar toast de error después de unos segundos
        const toastMessage = document.getElementById('toast-message');
        if (toastMessage) {
            setTimeout(() => {
                toastMessage.style.opacity = '0';
                setTimeout(() => toastMessage.remove(), 500);
            }, 5000);
        }
    </script>
}
