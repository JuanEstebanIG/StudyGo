@model StudyGo.ViewModels.QuizResultViewModel
@{
    ViewData["Title"] = "Resultados del Quiz";
}

<div class="mb-6">
    <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm text-slate-400 transition-colors hover:text-indigo-400">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Volver a Mis Evaluaciones
    </a>
</div>

<div class="mb-8">
    <h1 class="text-2xl font-bold text-white tracking-tight">Resultados: @Model.QuizTitle</h1>
    <p class="text-sm text-slate-400 mt-1">Curso: @Model.CourseName</p>
</div>

<!-- Header con Resultado Final -->
<div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-8 text-center mb-8 relative overflow-hidden">
    <!-- Decoración de fondo condicional -->
    @{
        var isPassed = Model.Score >= 60;
        var gradientClass = isPassed ? "from-emerald-500/10 to-emerald-500/0" : "from-red-500/10 to-red-500/0";
        var textColorClass = isPassed ? "text-emerald-400" : "text-red-400";
    }
    <div class="absolute inset-0 bg-gradient-to-b @gradientClass pointer-events-none"></div>

    <div class="relative z-10">
        <p class="text-sm font-semibold uppercase tracking-wider text-slate-400 mb-2">Tu Calificación</p>
        <div class="flex items-end justify-center gap-2 mb-2">
            <span class="text-6xl font-black @textColorClass leading-none tracking-tighter">@Model.Score</span>
            <span class="text-2xl font-bold text-slate-500 pb-1">/ 100</span>
        </div>
        <p class="text-slate-300 font-medium">@Model.CorrectAnswers de @Model.TotalQuestions respuestas correctas (@Model.Percentage%)</p>
    </div>
</div>

<!-- Métricas Secundarias -->
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    <div class="flex items-center gap-4 rounded-xl border border-slate-800 bg-slate-900/40 p-5">
        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-slate-800 text-slate-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
        </div>
        <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Tiempo Utilizado</p>
            <p class="text-lg font-bold text-white">@Model.TimeSpentDisplay</p>
            <p class="text-xs text-slate-500">De un máximo de @Model.TimeLimitMinutes min</p>
        </div>
    </div>
    
    <div class="flex items-center gap-4 rounded-xl border border-slate-800 bg-slate-900/40 p-5">
        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-slate-800 text-slate-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
        </div>
        <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Fecha de Envío</p>
            <p class="text-lg font-bold text-white">@Model.SubmittedAt.ToString("dd MMM yyyy")</p>
            <p class="text-xs text-slate-500">A las @Model.SubmittedAt.ToString("HH:mm") hrs</p>
        </div>
    </div>
</div>

<!-- Revisión Pregunta por Pregunta -->
<h2 class="text-lg font-semibold text-white mb-4 border-b border-slate-800 pb-2">Revisión Detallada</h2>

<div class="space-y-6">
    @for (int i = 0; i < Model.Details.Count; i++)
    {
        var detail = Model.Details[i];
        var blockBorderClass = detail.IsCorrect ? "border-emerald-500/30" : "border-red-500/30";
        var blockBgClass = detail.IsCorrect ? "bg-emerald-500/5" : "bg-red-500/5";
        var iconColor = detail.IsCorrect ? "text-emerald-500" : "text-red-500";
        var iconBg = detail.IsCorrect ? "bg-emerald-500/10" : "bg-red-500/10";
        
        <div class="rounded-xl border @blockBorderClass @blockBgClass p-5">
            <div class="flex items-start gap-4">
                <!-- Icono de estado -->
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full @iconBg @iconColor mt-0.5">
                    @if (detail.IsCorrect)
                    {
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                    }
                    else
                    {
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                        </svg>
                    }
                </div>

                <div class="flex-grow">
                    <h3 class="text-base font-medium text-white mb-3">
                        <span class="text-slate-500 mr-1">@(i + 1).</span> @detail.QuestionText
                    </h3>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <!-- Lo que respondiste -->
                        <div class="rounded-lg border border-slate-700/50 bg-slate-800/40 p-3">
                            <p class="text-xs font-semibold uppercase text-slate-500 mb-2">Tu Respuesta</p>
                            @if (detail.SelectedOptions.Any())
                            {
                                <ul class="space-y-1">
                                    @foreach (var opt in detail.SelectedOptions)
                                    {
                                        <li class="flex items-start gap-2 text-sm text-slate-300">
                                            <span class="mt-1 block h-1.5 w-1.5 shrink-0 rounded-full bg-slate-500"></span>
                                            @opt
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="text-sm italic text-slate-500">No respondiste esta pregunta</p>
                            }
                        </div>

                        <!-- La respuesta correcta -->
                        <div class="rounded-lg border border-slate-700/50 bg-slate-800/40 p-3">
                            <p class="text-xs font-semibold uppercase text-slate-500 mb-2">Respuesta Correcta</p>
                            <ul class="space-y-1">
                                @foreach (var opt in detail.CorrectOptions)
                                {
                                    <li class="flex items-start gap-2 text-sm text-emerald-400">
                                        <span class="mt-1 block h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500"></span>
                                        @opt
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-10 flex justify-center">
    <a asp-action="Index" class="rounded-lg bg-indigo-600 px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 transition-all hover:bg-indigo-500">
        Finalizar Revisión
    </a>
</div>
