@model StudyGo.ViewModels.Chat.ChatPageViewModel
@using StudyGo.ViewModels.Components
@{
    ViewData["Title"] = "Chat";
}

<div id="connection-alert" class="hidden fixed top-4 left-1/2 transform -translate-x-1/2 z-50 flex items-center gap-2 px-4 py-2 rounded-full shadow-lg border text-xs font-medium transition-all duration-300 bg-dark-card border-dark-border text-gray-100">
    <span id="connection-alert-icon" class="animate-spin h-3.5 w-3.5 border-2 border-brand-blue border-t-transparent rounded-full"></span>
    <span id="connection-alert-text">Reconectando...</span>
</div>

<div class="flex h-[calc(100vh-8rem)] card overflow-hidden" data-current-user-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value?.ToLower().Trim()">
    
    <aside class="w-100 flex flex-col border-r border-dark-border bg-dark-card shrink-0 transition-all duration-300">
        <div class="p-4 border-b border-dark-border flex flex-col gap-3">
            <div class="flex justify-between items-center">
                <h2 class="font-title font-bold text-lg text-gray-100">Mensajes</h2>
                <button id="openNewChatModalBtn" class="btn btn-sm btn-secondary p-2 rounded-xl text-brand-blue border-brand-blue/10 hover:bg-brand-blue/10" title="Nueva conversación">
                    <i class="fa-solid fa-plus text-sm"></i>
                </button>
            </div>
            <div class="relative">
                <i class="fa-solid fa-search absolute left-3 top-1/2 -translate-y-1/2 text-dark-muted text-xs"></i>
                <input type="text" class="input pl-9 py-2 text-xs" placeholder="Buscar conversación..." data-search-chat>
            </div>
        </div>

        <div class="flex-1 overflow-y-auto custom-scrollbar">
            @if (!Model.HasConversations)
            {
                <div class="p-6" data-conversations-empty>
                    <partial name="Components/_EmptyState" model='new EmptyStateModel { Icon = "fa-regular fa-comments", Title = "Sin mensajes", Message = "Aún no tienes conversaciones activas." }' />
                </div>
            }
            
            <ul class="flex flex-col @(Model.HasConversations ? "" : "hidden")" data-conversation-list>
                @foreach (var conv in Model.Conversations)
                {
                    var activeClass = conv.IsActive ? "bg-dark-elev border-l-2 border-brand-blue" : "border-l-2 border-transparent hover:bg-white/5 transition-colors";
                    
                    <li data-sidebar-chat-id="@conv.ChatId" class="group relative">
            
                        <button type="button"
                                data-leave-chat-btn="@conv.ChatId"
                                data-chat-title="@conv.Title"
                                class="absolute right-4 top-1/2 -translate-y-1/2 z-20 hidden group-hover:flex items-center justify-center w-7 h-7 rounded-xl bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500 hover:text-white transition-all duration-200 shadow-lg shadow-rose-500/10"
                                title="Eliminar conversación">
                            <i class="fa-solid fa-trash text-xs"></i>
                        </button>

                        <a href="/Chat/Index/@conv.ChatId" data-chat-link="@conv.ChatId" class="flex items-center gap-3 p-4 border-b border-dark-border/50 @activeClass">
                            <partial name="Components/_Avatar" model='new AvatarModel { Name = conv.Title, ImageUrl = conv.AvatarUrl }' />
                            <div class="flex-1 min-w-0 pr-4">
                                <div class="flex justify-between items-center gap-2 mb-1 w-full">
                                    <!-- Contenedor del Nombre y los Badges alineados a la izquierda -->
                                    <div class="flex items-center gap-1.5 min-w-0 flex-1">
                                        <h3 class="text-sm font-medium text-gray-100 truncate max-w-[55%] md:max-w-[60%] data-title">@conv.Title</h3>
        
                                        @if (conv.Type == StudyGo.Enums.ChatType.Privado)
                                        {
                                            @if (conv.TargetRole == "Administrador")
                                            {
                                                <span class="flex-shrink-0 px-1.5 py-0.5 rounded-md text-[9px] font-bold tracking-wide uppercase bg-rose-500/10 border border-rose-500/20 text-rose-400">Admin</span>
                                            }
                                            else if (conv.TargetRole == "Docente")
                                            {
                                                <span class="flex-shrink-0 px-1.5 py-0.5 rounded-md text-[9px] font-bold tracking-wide uppercase bg-purple-500/10 border border-purple-500/20 text-purple-400">Docente</span>
                                            }
                                            else
                                            {
                                                <span class="flex-shrink-0 px-1.5 py-0.5 rounded-md text-[9px] font-bold tracking-wide uppercase bg-emerald-500/10 border border-emerald-500/20 text-emerald-400">Estudiante</span>
                                            }
                                        }
                                    </div>
                                    <!-- Hora fija a la derecha sin pisarse -->
                                    <span class="font-mono text-[10px] text-dark-muted data-time flex-shrink-0">@(conv.LastMessageAt?.ToString("HH:mm") ?? "")</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <p class="text-xs text-dark-muted truncate data-preview">@conv.LastMessagePreview</p>
                                    @if (conv.UnreadCount > 0)
                                    {
                                        <span class="flex items-center justify-center w-4 h-4 rounded-full bg-brand-blue text-[9px] font-bold text-white data-unread">@conv.UnreadCount</span>
                                    }
                                </div>
                            </div>
                        </a>
                    </li>
                }
            </ul>
        </div>
    </aside>

    <main class="flex-1 flex flex-col bg-dark-bg/30 relative" data-chat-container data-active-chat-id="@Model.ActiveConversation?.ChatId">
        @if (Model.ActiveConversation == null)
        {
            <div class="flex-1 items-center justify-center flex" data-empty-thread>
                <partial name="Components/_EmptyState" model='new EmptyStateModel { Icon = "fa-regular fa-paper-plane", Title = "Tus mensajes", Message = "Elige una conversación o agrega un contacto para empezar a chatear." }' />
            </div>
            
            <div class="hidden flex-1 flex-col h-full" data-active-thread>
                <header class="flex items-center justify-between px-6 py-4 border-b border-dark-border glass-panel z-10">
                    <h2 class="font-title font-semibold text-gray-100" data-thread-title></h2>
                    <div data-connection-status class="hidden"></div>
                </header>
                <div class="flex-1 overflow-y-auto p-6 space-y-4 custom-scrollbar flex flex-col" data-chat-messages></div>
                <div class="p-4 bg-dark-card border-t border-dark-border">
                    <form class="flex items-end gap-3" data-chat-form>
                        @Html.AntiForgeryToken()
                        <div class="flex-1">
                            <textarea rows="1" class="input resize-none py-3 custom-scrollbar" placeholder="Escribe un mensaje..." data-chat-input required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary h-[42px] px-4 shrink-0 rounded-xl">
                            <i class="fa-solid fa-paper-plane text-sm"></i>
                        </button>
                    </form>
                    <div class="h-4 mt-1">
                        <span class="text-xs text-brand-blue italic opacity-0 transition-opacity" data-typing-indicator></span>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="flex-1 flex flex-col h-full" data-active-thread>
                <header class="flex items-center justify-between px-6 py-4 border-b border-dark-border glass-panel z-10">
                    <h2 class="font-title font-semibold text-gray-100" data-thread-title>@Model.ActiveConversation.Title</h2>
                    <div data-connection-status class="hidden">
                        <partial name="Components/_Badge" model='new BadgeModel { Text = "Conectando...", Variant = "warn" }' />
                    </div>
                </header>

                <div class="flex-1 overflow-y-auto p-6 space-y-4 custom-scrollbar flex flex-col" data-chat-messages>
                    @foreach (var msg in Model.ActiveConversation.Messages)
                    {
                        var isDeleted = msg.IsDeleted || msg.Content.Contains("🚫");
                        var justifyPosition = msg.IsOwn ? "justify-end" : "justify-start";
                        var extraClasses = isDeleted ? "italic opacity-80" : "";
        
                        var customStyle = "";
                        if (msg.IsOwn)
                        {
                            customStyle = isDeleted
                                ? "background-color: #cbd5e1 !important; color: #475569 !important; border: 1px solid #94a3b8 !important;"
                                : "background-color: #e2e8f0 !important; color: #1e293b !important; border: 1px solid #121214 !important;";
                        }

                        <div class="flex w-full @justifyPosition group" data-msg-id="@msg.Id">
                            <div class="flex flex-col max-w-[75%]">
                                <div class="flex @justifyPosition items-baseline gap-2 mb-1">
                    
                                    @if (msg.IsOwn && !isDeleted)
                                    {
                                        <button data-delete-btn="@msg.Id" class="text-xs text-rose-500 opacity-0 group-hover:opacity-100 transition-opacity mr-2 hover:text-rose-400" title="Eliminar para todos">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    }

                                    <span class="text-[10px] font-medium text-dark-muted">@(msg.IsOwn ? "Tú" : msg.SenderName)</span>
                                    <span class="font-mono text-[9px] text-dark-muted/60">@msg.SentAt.ToString("HH:mm")</span>
                                </div>
                
                                <div class="@(msg.IsOwn ? "ml-auto rounded-tr-sm" : "bg-dark-elev border border-dark-border mr-auto rounded-tl-sm") rounded-2xl px-4 py-2.5 text-sm shadow-sm whitespace-pre-wrap text-left @extraClasses" style="@customStyle">@msg.Content</div>
                            </div>
                        </div>
                    }
                </div>

                <div class="p-4 bg-dark-card border-t border-t-dark-border">
                    <form class="flex items-end gap-3" data-chat-form>
                        @Html.AntiForgeryToken()
                        <div class="flex-1">
                            <textarea rows="1" class="input resize-none py-3 custom-scrollbar" style="color: #f3f4f6 !important; background-color: #111214 !important;" placeholder="Escribe un mensaje... (Shift + Enter para salto)" data-chat-input required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary h-[42px] px-4 shrink-0 rounded-xl" data-chat-submit>
                            <i class="fa-solid fa-paper-plane text-sm"></i>
                        </button>
                    </form>
                    <div class="h-4 mt-1">
                        <span class="text-xs text-brand-blue italic opacity-0 transition-opacity" data-typing-indicator>Alguien está escribiendo...</span>
                    </div>
                </div>
            </div>
        }
    </main>
</div>

<div id="newChatModal" class="hidden fixed inset-0 bg-dark-bg/80 backdrop-blur-sm z-50 items-center justify-center p-4">
    <div class="glass-panel w-full max-w-md rounded-3xl p-6 shadow-xl transform scale-95 transition-transform duration-200" data-modal-content>
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-base font-semibold text-gray-100 font-title">Nueva conversación</h3>
            <button id="closeModalBtn" class="text-dark-muted hover:text-gray-100 transition-colors text-lg">&times;</button>
        </div>
        
        <div id="selectedUsersContainer" class="flex flex-wrap gap-2 mb-3 empty:hidden"></div>
        
        <div id="groupNameContainer" class="hidden flex-col gap-1.5 mb-4 transition-all duration-300">
            <label class="text-[11px] font-medium text-dark-muted">Nombre del grupo</label>
            <input type="text" id="groupNameInput"
                   class="w-full bg-dark-bg/60 border border-dark-border rounded-xl px-4 py-2.5 text-xs text-gray-100 placeholder-dark-muted focus:outline-none focus:border-brand-blue transition-colors font-sans"
                   style="color: #111214 !important; background-color: #f3f4f6 !important;"
                   placeholder="Ej: Equipo de Desarrollo - Sistemas" maxlength="50" autocomplete="off" />
        </div>

        <div class="relative mb-4">
            <i class="fa-regular fa-envelope absolute left-3 top-1/2 -translate-y-1/2 text-dark-muted text-xs"></i>
            <input type="email" id="emailSearchInput"
                   class="w-full bg-dark-bg/60 border border-dark-border rounded-xl pl-9 pr-10 py-2.5 text-xs font-sans text-gray-100 placeholder-dark-muted focus:outline-none focus:border-brand-blue transition-colors"
                   style="color: #111214 !important; background-color: #f3f4f6 !important;"
                   placeholder="Buscar por nombre o correo institucional..." autocomplete="off" />
            <div id="searchSpinner" class="hidden absolute right-3 top-1/2 -translate-y-1/2 h-3.5 w-3.5 border-2 border-brand-blue border-t-transparent rounded-full animate-spin"></div>
        </div>

        <div id="searchResultsContainer" class="hidden max-h-48 overflow-y-auto border border-dark-border rounded-xl divide-y divide-dark-border/40 bg-dark-bg/40 mb-4 custom-scrollbar">
        </div>

        <div id="searchErrorMsg" class="hidden text-xs text-rose-400 bg-red-400/10 border border-red-400/20 rounded-xl px-4 py-3 mb-4">
            <i class="fa-solid fa-triangle-exclamation mr-1"></i> No se encontró ningún usuario.
        </div>

        <div class="flex justify-end gap-2 text-xs mt-2">
            <button id="cancelModalBtn" class="btn btn-sm btn-secondary">Cancelar</button>
            <button id="startChatActionBtn" class="btn btn-sm btn-primary hidden px-4 py-2 rounded-xl">Iniciar Chat</button>
        </div>
    </div>
</div>

<div id="deleteConfirmModal" class="hidden fixed inset-0 bg-dark-bg/80 backdrop-blur-sm z-50 items-center justify-center p-4">
    <div class="glass-panel w-full max-w-sm rounded-3xl p-6 shadow-xl transform transition-transform duration-200 border border-dark-border">
        <div class="flex flex-col items-center text-center">
            
            <div class="w-14 h-14 rounded-full bg-rose-500/10 text-rose-500 flex items-center justify-center text-2xl mb-4 border border-rose-500/20">
                <i class="fa-solid fa-trash-can"></i>
            </div>
            
            <h3 class="text-lg font-semibold text-gray-100 font-title mb-2">¿Eliminar mensaje?</h3>
            <p class="text-xs text-dark-muted mb-6">Este mensaje será eliminado para todos los participantes de la conversación. Esta acción no se puede deshacer.</p>
            
            <div class="flex justify-center gap-3 w-full">
                <button id="cancelDeleteBtn" class="btn btn-secondary flex-1 py-2.5 rounded-xl text-xs font-medium">Cancelar</button>
                <button id="confirmDeleteBtn" class="flex-1 bg-rose-500 hover:bg-rose-600 text-white border border-rose-500/50 rounded-xl transition-colors font-medium text-xs py-2.5 shadow-lg shadow-rose-500/20">Eliminar para todos</button>
            </div>
            
        </div>
    </div>
</div>

<div id="chatLeaveConfirmModal" class="hidden fixed inset-0 bg-dark-bg/80 backdrop-blur-sm z-50 items-center justify-center p-4">
    <div class="glass-panel w-full max-w-sm rounded-3xl p-6 shadow-xl transform transition-transform duration-200 border border-dark-border">
        <div class="flex flex-col items-center text-center">
            <div class="w-14 h-14 rounded-full bg-rose-500/10 text-rose-500 flex items-center justify-center text-2xl mb-4 border border-rose-500/20">
                <i class="fa-solid fa-right-from-bracket"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-100 font-title mb-2" id="chatLeaveModalTitle">¿Eliminar conversación?</h3>
            <p class="text-xs text-dark-muted mb-6">Saldrás de esta conversación y ya no aparecerá en tu barra lateral. Los demás participantes continuarán en el chat.</p>
            <div class="flex justify-center gap-3 w-full">
                <button id="cancelLeaveChatBtn" class="btn btn-secondary flex-1 py-2.5 rounded-xl text-xs font-medium">Cancelar</button>
                <button id="confirmLeaveChatBtn" class="flex-1 bg-rose-500 hover:bg-rose-600 text-white border border-rose-500/50 rounded-xl transition-colors font-medium text-xs py-2.5 shadow-lg shadow-rose-500/20">Confirmar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}