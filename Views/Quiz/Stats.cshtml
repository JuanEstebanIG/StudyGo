@model IEnumerable<StudyGo.ViewModels.QuizAttemptViewModel>
@{
    ViewData["Title"] = "Estadísticas del Quiz";
}

<div class="min-h-screen bg-transparent py-10 px-4 sm:px-6 lg:px-8 font-sans antialiased">
<div class="max-w-5xl mx-auto">

<div class="mb-6">
    <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm text-slate-400 transition-colors hover:text-indigo-400">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Volver al Dashboard
    </a>
</div>

<div class="mb-8">
    <h1 class="text-2xl font-bold text-white tracking-tight">@ViewBag.QuizTitle</h1>
    <p class="text-sm text-slate-400 mt-1">Estadísticas y resultados de los estudiantes para este quiz del curso <span class="text-indigo-400 font-medium">@ViewBag.CourseName</span>.</p>
</div>

<!-- Métricas Rápidas -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
        <p class="text-sm font-medium text-slate-400">Total de Intentos</p>
        <p class="text-2xl font-bold text-white">@Model.Count()</p>
    </div>
    <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
        <p class="text-sm font-medium text-slate-400">Promedio de Calificaciones</p>
        <p class="text-2xl font-bold text-white">@ViewBag.AverageScore.ToString("0.0") / 100</p>
    </div>
    <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
        <p class="text-sm font-medium text-slate-400">Total de Preguntas</p>
        <p class="text-2xl font-bold text-white">@ViewBag.TotalQuestions</p>
    </div>
</div>

<!-- Tabla de Intentos -->
<div class="rounded-xl border border-slate-800 bg-slate-900/50 overflow-hidden">
    @if (Model.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-slate-800/50 border-b border-slate-800">
                    <tr>
                        <th class="px-4 py-3 font-medium text-slate-400">Estudiante</th>
                        <th class="px-4 py-3 font-medium text-slate-400">Fecha de Envío</th>
                        <th class="px-4 py-3 font-medium text-slate-400">Tiempo Usado</th>
                        <th class="px-4 py-3 font-medium text-slate-400">Puntaje</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    @foreach (var attempt in Model)
                    {
                        <tr class="hover:bg-slate-800/30 transition-colors">
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-3">
                                    <div class="flex h-8 w-8 items-center justify-center rounded-full bg-indigo-500/20 text-indigo-400 font-bold">
                                        @(((Dictionary<Guid, string>)ViewBag.StudentNames)[attempt.Id].Substring(0, 1).ToUpper())
                                    </div>
                                    <span class="font-medium text-white">@(((Dictionary<Guid, string>)ViewBag.StudentNames)[attempt.Id])</span>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-slate-300">@attempt.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-4 py-3 font-mono text-slate-300">@attempt.TimeSpentDisplay</td>
                            <td class="px-4 py-3">
                                @{
                                    var scoreColor = attempt.Score >= 60 ? "text-emerald-400" : "text-red-400";
                                }
                                <span class="font-bold @scoreColor">@attempt.Score</span> / 100
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="py-12 text-center">
            <p class="text-slate-400">Aún no hay intentos registrados para este quiz.</p>
        </div>
    }
</div>

</div>
</div>
