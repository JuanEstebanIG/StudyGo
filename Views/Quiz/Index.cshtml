@model StudyGo.ViewModels.QuizDashboardViewModel
@{
    ViewData["Title"] = "Gestión de Evaluaciones";
}

<!-- Sección A: Métricas Rápidas -->
<div class="mb-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-white tracking-tight">Gestión de Evaluaciones</h1>
            <p class="text-sm text-slate-400 mt-1">Administra tus quizzes, preguntas y revisa el rendimiento de tus estudiantes.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <!-- Métrica: Total Quizzes -->
        <div class="relative overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50 p-5 backdrop-blur-sm">
            <div class="flex items-center gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-medium text-slate-400">Total Quizzes</p>
                    <p class="text-2xl font-bold text-white">@Model.TotalQuizzes</p>
                </div>
            </div>
            <div class="absolute -right-3 -top-3 h-20 w-20 rounded-full bg-indigo-500/5"></div>
        </div>

        <!-- Métrica: Evaluaciones Activas -->
        <div class="relative overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50 p-5 backdrop-blur-sm">
            <div class="flex items-center gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-medium text-slate-400">Activas</p>
                    <p class="text-2xl font-bold text-white">@Model.ActiveQuizzes</p>
                </div>
            </div>
            <div class="absolute -right-3 -top-3 h-20 w-20 rounded-full bg-emerald-500/5"></div>
        </div>

        <!-- Métrica: Intentos Recibidos -->
        <div class="relative overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50 p-5 backdrop-blur-sm">
            <div class="flex items-center gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-amber-500/10 text-amber-400">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-medium text-slate-400">Intentos Recibidos</p>
                    <p class="text-2xl font-bold text-white">@Model.PendingAttempts</p>
                </div>
            </div>
            <div class="absolute -right-3 -top-3 h-20 w-20 rounded-full bg-amber-500/5"></div>
        </div>
    </div>
</div>

<!-- Toast de éxito -->
@if (TempData["SuccessMessage"] != null)
{
    <div id="toast-success" class="mb-6 flex items-center gap-3 rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-300 transition-all duration-500">
        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

<!-- Sección B: Acción Principal -->
<div class="mb-8">
    <a asp-action="Create"
       class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 transition-all duration-200 hover:bg-indigo-500 hover:shadow-indigo-500/30 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-slate-900">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Crear Nuevo Quiz
    </a>
</div>

<!-- Sección C: Tabla de Gestión por Curso -->
@if (Model.CourseGroups.Any())
{
    @foreach (var group in Model.CourseGroups)
    {
        <div class="mb-8">
            <div class="mb-3 flex items-center gap-2">
                <div class="h-2 w-2 rounded-full bg-indigo-500"></div>
                <h2 class="text-lg font-semibold text-white">@group.CourseName</h2>
                <span class="rounded-full bg-slate-800 px-2.5 py-0.5 text-xs font-medium text-slate-400">@group.Quizzes.Count quizzes</span>
            </div>

            <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-slate-800 text-left">
                                <th class="px-4 py-3 font-medium text-slate-400">Título</th>
                                <th class="px-4 py-3 font-medium text-slate-400">Estado</th>
                                <th class="px-4 py-3 font-medium text-slate-400">Duración</th>
                                <th class="px-4 py-3 font-medium text-slate-400">Preguntas</th>
                                <th class="px-4 py-3 font-medium text-slate-400">Fecha Límite</th>
                                <th class="px-4 py-3 font-medium text-slate-400">Intentos</th>
                                <th class="px-4 py-3 font-medium text-slate-400 text-right">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800/50">
                            @foreach (var quiz in group.Quizzes)
                            {
                                <tr class="transition-colors duration-150 hover:bg-slate-800/30">
                                    <td class="px-4 py-3">
                                        <span class="font-medium text-white">@quiz.Title</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        @{
                                            var stateColor = quiz.StateName switch
                                            {
                                                "Publicado" => "bg-emerald-500/10 text-emerald-400 border-emerald-500/20",
                                                "Borrador" => "bg-slate-500/10 text-slate-400 border-slate-500/20",
                                                "Cerrado" => "bg-red-500/10 text-red-400 border-red-500/20",
                                                _ => "bg-slate-500/10 text-slate-400 border-slate-500/20"
                                            };
                                        }
                                        <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium @stateColor">
                                            @quiz.StateName
                                        </span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="flex items-center gap-1.5 text-slate-300">
                                            <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                            </svg>
                                            @quiz.TimeLimitMinutes min
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-slate-300">@quiz.QuestionCount</td>
                                    <td class="px-4 py-3 text-slate-300">
                                        @(quiz.DueDate?.ToString("dd/MM/yyyy HH:mm") ?? "Sin fecha")
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="font-mono text-slate-300">@quiz.TotalAttempts</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center justify-end gap-1">
                                            <a asp-action="Edit" asp-route-id="@quiz.Id"
                                               class="rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-800 hover:text-indigo-400"
                                               title="Editar">
                                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                                                </svg>
                                            </a>
                                            <a asp-action="Stats" asp-route-id="@quiz.Id"
                                               class="rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-800 hover:text-emerald-400"
                                               title="Estadísticas">
                                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
                                                </svg>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@quiz.Id" method="post"
                                                  onsubmit="return confirm('¿Estás seguro de que deseas eliminar este quiz? Esta acción no se puede deshacer.');"
                                                  class="inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-800 hover:text-red-400"
                                                        title="Eliminar">
                                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
else
{
    <!-- Estado vacío -->
    <div class="flex flex-col items-center justify-center rounded-xl border border-dashed border-slate-700 bg-slate-900/30 py-16 text-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-slate-800 mb-4">
            <svg class="h-8 w-8 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">Sin evaluaciones</h3>
        <p class="text-sm text-slate-400 mb-6 max-w-sm">Aún no has creado ningún quiz. Comienza creando tu primera evaluación.</p>
        <a asp-action="Create"
           class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-indigo-500">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Crear primer quiz
        </a>
    </div>
}

@section Scripts {
    <script>
        // Auto-ocultar toast después de 4 segundos
        const toast = document.getElementById('toast-success');
        if (toast) {
            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 500);
            }, 4000);
        }
    </script>
}
