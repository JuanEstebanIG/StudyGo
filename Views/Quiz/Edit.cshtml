@model StudyGo.ViewModels.QuizViewModel
@{
    ViewData["Title"] = "Editar Quiz";
}

<div class="min-h-screen bg-transparent py-10 px-4 sm:px-6 lg:px-8 font-sans antialiased">
<div class="max-w-4xl mx-auto">

<div class="mb-6">
    <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm text-slate-400 transition-colors hover:text-indigo-400">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Volver al Dashboard
    </a>
</div>

<h1 class="text-2xl font-bold text-white tracking-tight mb-6">Editar Quiz</h1>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" id="quizForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <!-- Sección A: Datos de Configuración -->
    <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 mb-6">
        <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
            Configuración del Quiz
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
                <label asp-for="Title" class="block text-sm font-medium text-slate-300 mb-1.5"></label>
                <input asp-for="Title" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2.5 text-sm text-white placeholder-slate-500 transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
                <span asp-validation-for="Title" class="text-xs text-red-400 mt-1"></span>
            </div>
            <div class="md:col-span-2">
                <label asp-for="Description" class="block text-sm font-medium text-slate-300 mb-1.5"></label>
                <textarea asp-for="Description" rows="3" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2.5 text-sm text-white placeholder-slate-500 transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 resize-none"></textarea>
                <span asp-validation-for="Description" class="text-xs text-red-400 mt-1"></span>
            </div>
            <div>
                <label asp-for="CourseId" class="block text-sm font-medium text-slate-300 mb-1.5">Curso</label>
                <select asp-for="CourseId" asp-items="Model.AvailableCourses" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2.5 text-sm text-white transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                    <option value="">Selecciona un curso...</option>
                </select>
                <span asp-validation-for="CourseId" class="text-xs text-red-400 mt-1"></span>
            </div>
            <div>
                <label asp-for="SelectionMode" class="block text-sm font-medium text-slate-300 mb-1.5"></label>
                <select asp-for="SelectionMode" id="quizSelectionMode" asp-items="Html.GetEnumSelectList<StudyGo.Enums.SelectionMode>()" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2.5 text-sm text-white transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                </select>
                <span asp-validation-for="SelectionMode" class="text-xs text-red-400 mt-1"></span>
            </div>
            <div>
                <label asp-for="TimeLimitMinutes" class="block text-sm font-medium text-slate-300 mb-1.5">
                    <span class="flex items-center gap-1.5">
                        <svg class="h-4 w-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                        Tiempo Máximo (minutos)
                    </span>
                </label>
                <input asp-for="TimeLimitMinutes" type="number" min="1" max="300" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2.5 text-sm text-white transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
                <span asp-validation-for="TimeLimitMinutes" class="text-xs text-red-400 mt-1"></span>
            </div>
            <div>
                <label asp-for="MaxAttempts" class="block text-sm font-medium text-slate-300 mb-1.5"></label>
                <input asp-for="MaxAttempts" type="number" min="1" max="10" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2.5 text-sm text-white transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
                <span asp-validation-for="MaxAttempts" class="text-xs text-red-400 mt-1"></span>
            </div>
            <div>
                <label asp-for="OpenDate" class="block text-sm font-medium text-slate-300 mb-1.5"></label>
                <input asp-for="OpenDate" type="datetime-local" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2.5 text-sm text-white transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div>
                <label asp-for="DueDate" class="block text-sm font-medium text-slate-300 mb-1.5"></label>
                <input asp-for="DueDate" type="datetime-local" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2.5 text-sm text-white transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div>
                <label asp-for="State" class="block text-sm font-medium text-slate-300 mb-1.5"></label>
                <select asp-for="State" asp-items="Html.GetEnumSelectList<StudyGo.Enums.ActivityState>()" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2.5 text-sm text-white transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"></select>
            </div>
        </div>
    </div>

    <!-- Sección B: Constructor de Preguntas -->
    <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-white flex items-center gap-2">
                <svg class="h-5 w-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                </svg>
                Preguntas del Quiz
            </h2>
            <button type="button" id="btnAddQuestion"
                    class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2 text-sm font-medium text-slate-300 transition-all hover:border-indigo-500 hover:text-indigo-400">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Añadir Pregunta
            </button>
        </div>

        <div id="questionsContainer">
            @for (int i = 0; i < Model.Questions.Count; i++)
            {
                <div class="question-card rounded-xl border border-slate-700 bg-slate-800/50 p-5 mb-4" data-index="@i">
                    <!-- IDs ocultos: ESTO ES LO QUE FALTABA -->
                    <input type="hidden" asp-for="Questions[i].Id" />
                    <input type="hidden" asp-for="Questions[i].Order" value="@i" />
                    <input type="hidden" asp-for="Questions[i].QuestionType" />

                    <div class="flex items-center justify-between mb-3">
                        <span class="text-sm font-semibold text-indigo-400 question-number">Pregunta @(i + 1)</span>
                        <button type="button" class="btn-remove-question inline-flex items-center gap-1 rounded-md border border-red-900/50 bg-red-900/20 px-2.5 py-1 text-xs font-medium text-red-400 transition-colors hover:bg-red-900/30">
                            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                            </svg>
                            Eliminar
                        </button>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Questions[i].QuestionText" class="block text-xs font-medium text-slate-400 mb-1">Texto de la pregunta</label>
                        <input asp-for="Questions[i].QuestionText" class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white placeholder-slate-500 transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="Escribe la pregunta..." />
                        <span asp-validation-for="Questions[i].QuestionText" class="text-xs text-red-400 mt-1"></span>
                    </div>

                    <div class="options-wrapper space-y-2 mb-3">
                        @for (int j = 0; j < Model.Questions[i].Options.Count; j++)
                        {
                            <div class="option-row flex items-center gap-2" data-option-index="@j">
                                <input type="hidden" asp-for="Questions[i].Options[j].Id" />

                                <div class="flex-1">
                                    <input asp-for="Questions[i].Options[j].OptionText" class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-1.5 text-sm text-white placeholder-slate-500 transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="Opción @(j + 1)" />
                                </div>

                                <label class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 bg-slate-900 px-3 py-1.5 text-sm text-slate-300 cursor-pointer select-none hover:border-indigo-500 transition-colors">
                                    <input asp-for="Questions[i].Options[j].IsCorrect" class="h-4 w-4 rounded border-slate-600 bg-slate-800 text-indigo-500 focus:ring-indigo-500" />
                                    <span class="text-xs">Correcta</span>
                                </label>

                                <button type="button" class="btn-remove-option rounded-md p-1.5 text-slate-500 hover:text-red-400 hover:bg-red-900/20 transition-colors">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                                    </svg>
                                </button>
                            </div>
                        }
                    </div>

                    <button type="button" class="btn-add-option inline-flex items-center gap-1.5 rounded-lg border border-slate-700 bg-slate-800 px-3 py-1.5 text-xs font-medium text-slate-300 transition-all hover:border-indigo-500 hover:text-indigo-400">
                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        </svg>
                        Añadir Opción
                    </button>
                </div>
            }
        </div>

        <div id="emptyQuestionsState" class="@(Model.Questions.Any() ? "hidden" : "") flex flex-col items-center justify-center rounded-lg border border-dashed border-slate-700 py-10 text-center">
            <p class="text-sm text-slate-500">No hay preguntas aún. Añade la primera para comenzar.</p>
        </div>
    </div>

    <div class="flex items-center justify-end gap-3">
        <a asp-action="Index" class="rounded-lg border border-slate-700 bg-slate-800 px-5 py-2.5 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-700">Cancelar</a>
        <button type="submit" class="rounded-lg bg-indigo-600 px-6 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 transition-all hover:bg-indigo-500 hover:shadow-indigo-500/30 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-slate-900">
            Actualizar Quiz
        </button>
    </div>

    <!-- Template para nuevas preguntas (Guid.Empty = nueva) -->
    <template id="question-template">
        <div class="question-card rounded-xl border border-slate-700 bg-slate-800/50 p-5 mb-4" data-index="{{index}}">
            <input type="hidden" name="Questions[{{index}}].Id" value="00000000-0000-0000-0000-000000000000" />
            <input type="hidden" name="Questions[{{index}}].Order" value="{{index}}" />
            <input type="hidden" name="Questions[{{index}}].QuestionType" value="0" />

            <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-semibold text-indigo-400 question-number">Pregunta {{displayIndex}}</span>
                <button type="button" class="btn-remove-question inline-flex items-center gap-1 rounded-md border border-red-900/50 bg-red-900/20 px-2.5 py-1 text-xs font-medium text-red-400 transition-colors hover:bg-red-900/30">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                    Eliminar
                </button>
            </div>

            <div class="mb-3">
                <label class="block text-xs font-medium text-slate-400 mb-1">Texto de la pregunta</label>
                <input name="Questions[{{index}}].QuestionText" class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white placeholder-slate-500 transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="Escribe la pregunta..." />
            </div>

            <div class="options-wrapper space-y-2 mb-3">
                <div class="option-row flex items-center gap-2" data-option-index="0">
                    <input type="hidden" name="Questions[{{index}}].Options[0].Id" value="00000000-0000-0000-0000-000000000000" />
                    <div class="flex-1">
                        <input name="Questions[{{index}}].Options[0].OptionText" class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-1.5 text-sm text-white placeholder-slate-500 transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="Opción 1" />
                    </div>
                    <label class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 bg-slate-900 px-3 py-1.5 text-sm text-slate-300 cursor-pointer select-none hover:border-indigo-500 transition-colors">
                        <input type="checkbox" name="Questions[{{index}}].Options[0].IsCorrect" value="true" class="h-4 w-4 rounded border-slate-600 bg-slate-800 text-indigo-500 focus:ring-indigo-500" />
                        <input type="hidden" name="Questions[{{index}}].Options[0].IsCorrect" value="false" />
                        <span class="text-xs">Correcta</span>
                    </label>
                    <button type="button" class="btn-remove-option rounded-md p-1.5 text-slate-500 hover:text-red-400 hover:bg-red-900/20 transition-colors">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
                <div class="option-row flex items-center gap-2" data-option-index="1">
                    <input type="hidden" name="Questions[{{index}}].Options[1].Id" value="00000000-0000-0000-0000-000000000000" />
                    <div class="flex-1">
                        <input name="Questions[{{index}}].Options[1].OptionText" class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-1.5 text-sm text-white placeholder-slate-500 transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="Opción 2" />
                    </div>
                    <label class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 bg-slate-900 px-3 py-1.5 text-sm text-slate-300 cursor-pointer select-none hover:border-indigo-500 transition-colors">
                        <input type="checkbox" name="Questions[{{index}}].Options[1].IsCorrect" value="true" class="h-4 w-4 rounded border-slate-600 bg-slate-800 text-indigo-500 focus:ring-indigo-500" />
                        <input type="hidden" name="Questions[{{index}}].Options[1].IsCorrect" value="false" />
                        <span class="text-xs">Correcta</span>
                    </label>
                    <button type="button" class="btn-remove-option rounded-md p-1.5 text-slate-500 hover:text-red-400 hover:bg-red-900/20 transition-colors">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>

            <button type="button" class="btn-add-option inline-flex items-center gap-1.5 rounded-lg border border-slate-700 bg-slate-800 px-3 py-1.5 text-xs font-medium text-slate-300 transition-all hover:border-indigo-500 hover:text-indigo-400">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Añadir Opción
            </button>
        </div>
    </template>

    <!-- Template para nuevas opciones -->
    <template id="option-template">
        <div class="option-row flex items-center gap-2" data-option-index="{{optionIndex}}">
            <input type="hidden" name="Questions[{{qIndex}}].Options[{{optionIndex}}].Id" value="00000000-0000-0000-0000-000000000000" />
            <div class="flex-1">
                <input name="Questions[{{qIndex}}].Options[{{optionIndex}}].OptionText" class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-1.5 text-sm text-white placeholder-slate-500 transition-colors focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="Nueva opción" />
            </div>
            <label class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 bg-slate-900 px-3 py-1.5 text-sm text-slate-300 cursor-pointer select-none hover:border-indigo-500 transition-colors">
                <input type="checkbox" name="Questions[{{qIndex}}].Options[{{optionIndex}}].IsCorrect" value="true" class="h-4 w-4 rounded border-slate-600 bg-slate-800 text-indigo-500 focus:ring-indigo-500" />
                <input type="hidden" name="Questions[{{qIndex}}].Options[{{optionIndex}}].IsCorrect" value="false" />
                <span class="text-xs">Correcta</span>
            </label>
            <button type="button" class="btn-remove-option rounded-md p-1.5 text-slate-500 hover:text-red-400 hover:bg-red-900/20 transition-colors">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
    </template>
</form>

</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const container = document.getElementById('questionsContainer');
            const emptyState = document.getElementById('emptyQuestionsState');
            const btnAddQuestion = document.getElementById('btnAddQuestion');
            const questionTpl = document.getElementById('question-template').innerHTML;
            const optionTpl = document.getElementById('option-template').innerHTML;

            function updateEmptyState() {
                if (container.children.length === 0) {
                    emptyState.classList.remove('hidden');
                } else {
                    emptyState.classList.add('hidden');
                }
            }

            // Reindexa TODAS las preguntas y sus opciones para que el Model Binder reciba arrays consecutivos
            function reindexAll() {
                const cards = container.querySelectorAll('.question-card');
                cards.forEach((card, qIdx) => {
                    card.dataset.index = qIdx;

                    // Reemplaza Questions[old] -> Questions[qIdx] en names, ids y fors
                    const pattern = /Questions\[\d+\]/g;
                    const replacement = `Questions[${qIdx}]`;

                    card.querySelectorAll('[name]').forEach(el => el.name = el.name.replace(pattern, replacement));
                    card.querySelectorAll('[id]').forEach(el => el.id = el.id.replace(pattern, replacement));
                    card.querySelectorAll('[for]').forEach(el => {
                        const f = el.getAttribute('for');
                        if (f) el.setAttribute('for', f.replace(pattern, replacement));
                    });

                    // Actualiza número visible
                    const numEl = card.querySelector('.question-number');
                    if (numEl) numEl.textContent = `Pregunta ${qIdx + 1}`;

                    // Actualiza campo Order
                    const orderInput = card.querySelector('input[name$=".Order"]');
                    if (orderInput) orderInput.value = qIdx;

                    // Reindexa las opciones internas
                    reindexOptions(card, qIdx);
                });
            }

            function reindexOptions(questionCard, qIdx) {
                const rows = questionCard.querySelectorAll('.option-row');
                rows.forEach((row, oIdx) => {
                    row.dataset.optionIndex = oIdx;
                    const pattern = /Questions\[\d+\]\.Options\[\d+\]/g;
                    const replacement = `Questions[${qIdx}].Options[${oIdx}]`;

                    row.querySelectorAll('[name]').forEach(el => el.name = el.name.replace(pattern, replacement));
                    row.querySelectorAll('[id]').forEach(el => el.id = el.id.replace(pattern, replacement));
                    row.querySelectorAll('[for]').forEach(el => {
                        const f = el.getAttribute('for');
                        if (f) el.setAttribute('for', f.replace(pattern, replacement));
                    });

                    const txt = row.querySelector('input[name$=".OptionText"]');
                    if (txt) txt.placeholder = `Opción ${oIdx + 1}`;
                });
            }

            function addQuestion() {
                const count = container.querySelectorAll('.question-card').length;
                const html = questionTpl
                    .replace(/{{index}}/g, count)
                    .replace(/{{displayIndex}}/g, count + 1);

                const wrapper = document.createElement('div');
                wrapper.innerHTML = html.trim();
                container.appendChild(wrapper.firstElementChild);
                updateEmptyState();
            }

            function addOption(btn) {
                const questionCard = btn.closest('.question-card');
                const qIdx = parseInt(questionCard.dataset.index, 10);
                const wrapper = questionCard.querySelector('.options-wrapper');
                const count = wrapper.querySelectorAll('.option-row').length;

                const html = optionTpl
                    .replace(/{{qIndex}}/g, qIdx)
                    .replace(/{{optionIndex}}/g, count);

                const div = document.createElement('div');
                div.innerHTML = html.trim();
                wrapper.appendChild(div.firstElementChild);
                // No hace falta reindexar si solo append, pero por seguridad:
                reindexOptions(questionCard, qIdx);
            }

            function removeQuestion(btn) {
                btn.closest('.question-card').remove();
                reindexAll();
                updateEmptyState();
            }

            function removeOption(btn) {
                const row = btn.closest('.option-row');
                const questionCard = row.closest('.question-card');
                const qIdx = parseInt(questionCard.dataset.index, 10);
                row.remove();
                reindexOptions(questionCard, qIdx);
            }

            // Delegación de eventos
            container.addEventListener('click', function (e) {
                const btn = e.target.closest('button');
                if (!btn) return;

                if (btn.classList.contains('btn-add-option')) {
                    e.preventDefault();
                    addOption(btn);
                } else if (btn.classList.contains('btn-remove-question')) {
                    e.preventDefault();
                    removeQuestion(btn);
                } else if (btn.classList.contains('btn-remove-option')) {
                    e.preventDefault();
                    removeOption(btn);
                }
            });

            btnAddQuestion.addEventListener('click', function (e) {
                e.preventDefault();
                addQuestion();
            });

            updateEmptyState();
        })();
    </script>
}