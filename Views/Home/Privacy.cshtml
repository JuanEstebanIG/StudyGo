@{
    ViewData["Title"] = "Política de Privacidad";
}

<div class="max-w-3xl mx-auto space-y-8 animate-fade-in">
    <div class="border-b border-slate-800 pb-6">
        <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
            @ViewData["Title"]
        </h1>
        <p class="mt-2 text-sm text-slate-400">
            Última actualización: Junio 2026
        </p>
    </div>

    <div class="rounded-2xl border border-slate-950 bg-slate-900/40 p-6 md:p-8 space-y-6 backdrop-blur-sm">
        <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-500/10 text-indigo-400">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
            </div>
            <div>
                <h2 class="text-lg font-semibold text-white">Compromiso con la Seguridad</h2>
                <p class="mt-2 text-slate-300 text-sm leading-relaxed">
                    Utiliza esta sección para detallar las políticas de privacidad de **StudyGo**. Aquí puedes explicarle a tus usuarios cómo se recopilan, almacenan y protegen sus datos personales dentro de la plataforma.
                </p>
            </div>
        </div>

        <hr class="border-slate-800" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2">
            <div class="space-y-2">
                <h3 class="text-sm font-medium text-indigo-400 flex items-center gap-2">
                    <span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span>
                    Datos Recopilados
                </h3>
                <p class="text-xs text-slate-400 leading-relaxed">
                    Especifica si tu sistema almacena cookies, información de sesiones, credenciales o datos de perfil de usuario.
                </p>
            </div>

            <div class="space-y-2">
                <h3 class="text-sm font-medium text-emerald-400 flex items-center gap-2">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                    Uso de la Información
                </h3>
                <p class="text-xs text-slate-400 leading-relaxed">
                    Asegura a tus usuarios que sus datos solo se utilizan para mejorar la experiencia de desarrollo o gestionar las funcionalidades internas del sistema.
                </p>
            </div>
        </div>
    </div>

    <div class="rounded-xl border border-dashed border-slate-800 p-4 bg-slate-900/10 text-center">
        <p class="text-xs text-slate-400">
            ¿Tienes dudas sobre cómo manejamos la seguridad? Contacta al administrador del sistema.
        </p>
    </div>
</div>